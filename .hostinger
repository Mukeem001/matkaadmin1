{
  "name": "matka-api-server",
  "description": "Matka Admin Panel - Express.js API Server",
  "framework": "express",
  "language": "typescript",
  "runtime": "node-20",
  "buildCommand": "npm install && npm run build",
  "startCommand": "npm start",
  "postInstallCommand": "npm run typecheck",
  "environmentVariables": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "DATABASE_URL": "",
    "JWT_SECRET": "",
    "FRONTEND_URL": ""
  },
  "healthCheck": {
    "path": "/health",
    "interval": 30,
    "timeout": 10
  }
}
